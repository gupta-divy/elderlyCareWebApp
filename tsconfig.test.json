{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": false,
    "outDir": ".codex-tests",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": [
    "src/domain/**/*.ts",
    "src/features/family/**/*.ts",
    "src/features/documents/documentData.ts",
    "src/features/documents/documentImage.ts",
    "src/features/tasks/taskAlarmService.ts",
    "src/features/tasks/taskData.ts",
    "src/features/tasks/taskRecurrence.ts",
    "src/features/tasks/taskValidation.ts",
    "src/types/**/*.ts",
    "src/utils/helpers.ts",
    "src/data/seed.ts"
  ]
}
